#include <Servo.h>

Servo myServo;

int touchPin = 2;

void setup() {
  pinMode(touchPin, INPUT);
  myServo.attach(9);
  myServo.write(0); // стартовая позиция
}

void loop() {
  int touchState = digitalRead(touchPin);

  if (touchState == HIGH) {
    myServo.write(180); // открыть
  } else {
    myServo.write(0); // закрыть
  }
}
