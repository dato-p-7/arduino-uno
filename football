// Servo + 2 Buttons — Left / Right control
// Button 1 (D2) → turn left   (decrease angle)
// Button 2 (D3) → turn right  (increase angle)

#include <Servo.h>

const int BTN_LEFT  = 2;   // Button 1 pin
const int BTN_RIGHT = 3;   // Button 2 pin
const int SERVO_PIN = 9;   // Servo signal pin

const int STEP      = 20;   // Degrees per step
const int MIN_ANGLE = 20;
const int MAX_ANGLE = 160;
const int DELAY_MS  = 5;  // Speed (lower = faster)

Servo myServo;
int angle = 90;  // Start at center

void setup() {
  myServo.attach(SERVO_PIN);
  myServo.write(angle);

  // INPUT_PULLUP: no resistors needed
  // Button connects pin to GND when pressed
  pinMode(BTN_LEFT,  INPUT_PULLUP);
  pinMode(BTN_RIGHT, INPUT_PULLUP);
}

void loop() {
  bool leftPressed  = (digitalRead(BTN_LEFT)  == LOW);
  bool rightPressed = (digitalRead(BTN_RIGHT) == LOW);

  if (leftPressed) {
    angle = max(MIN_ANGLE, angle - STEP);
    myServo.write(angle);
  }

  if (rightPressed) {
    angle = min(MAX_ANGLE, angle + STEP);
    myServo.write(angle);
  }

  delay(DELAY_MS);
}
